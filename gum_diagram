#!/usr/bin/env bash
# Wrapper to run gum_diagram.py with its dedicated venv.
# If the venv is missing, set up a new one and install sympy first.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$HOME/dev/gum-venv"
PYTHON="$VENV_DIR/bin/python"

if [[ ! -x "$PYTHON" ]]; then
    echo "Setting up Python virtual environment in $VENV_DIR ..."
    python3 -m venv "$VENV_DIR"
    "$VENV_DIR/bin/pip" install --quiet sympy pytest
    echo "Done."
fi

exec "$PYTHON" "$SCRIPT_DIR/gum_diagram.py" "$@"
